generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url= env("postgresql://dakshvyawhare@localhost:5432/transitops")
}

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(DRIVER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}